<Page
    x:Class="SqlViewer.Views.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:SqlViewer.Core.Models"
    xmlns:controls="using:Microsoft.UI.Xaml.Controls"
    xmlns:local="using:SqlViewer.Views"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Page.Resources>
        <local:DateTimeToStringConverter x:Key="DateTimeToStringConverter" />
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250" />
            <ColumnDefinition Width="300" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Left Panel -->
        <Grid Grid.Column="0" Grid.Row="0" BorderBrush="{ThemeResource SystemControlForegroundBaseLowBrush}" BorderThickness="0,0,1,0" Padding="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            
            <Button Content="Klasör Seç" Click="SelectFolder_Click" HorizontalAlignment="Stretch" Margin="0,0,0,10" />
            
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <Expander Header="Dosyalar" IsExpanded="True" HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch" Margin="0,0,0,10">
                        <TreeView x:Name="FolderTreeView"
                                  ItemsSource="{x:Bind ViewModel.FolderTree, Mode=OneWay}"
                                  ItemInvoked="FolderTreeView_ItemInvoked"
                                  MaxHeight="400">
                            <TreeView.ItemTemplate>
                                <DataTemplate x:DataType="models:FolderNode">
                                    <TreeViewItem>
                                        <StackPanel Orientation="Horizontal" Spacing="5">
                                            <TextBlock Text="📁" FontSize="11" />
                                            <TextBlock Text="{x:Bind Name}" FontSize="12" />
                                        </StackPanel>
                                    </TreeViewItem>
                                </DataTemplate>
                            </TreeView.ItemTemplate>
                        </TreeView>
                    </Expander>

                    <Expander Header="Kategoriler" IsExpanded="False" HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch" Margin="0,0,0,10">
                        <ListView ItemsSource="{x:Bind ViewModel.Categories, Mode=OneWay}" SelectionMode="Single" MaxHeight="200">
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="models:Category">
                                    <TextBlock Text="{x:Bind Name}" FontSize="12" TextWrapping="Wrap" />
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Expander>

                    <Expander Header="Favoriler" IsExpanded="False" HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch" Margin="0,0,0,10">
                        <ListView ItemsSource="{x:Bind ViewModel.Favorites, Mode=OneWay}" SelectionMode="Single" MaxHeight="200">
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="models:Favorite">
                                    <TextBlock Text="{x:Bind FilePath}" FontSize="12" TextWrapping="Wrap" />
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Expander>

                    <Expander Header="Son Açılanlar" IsExpanded="False" HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch">
                        <ListView ItemsSource="{x:Bind ViewModel.RecentFiles, Mode=OneWay}" SelectionMode="Single" MaxHeight="200">
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="models:RecentFile">
                                    <TextBlock Text="{x:Bind FilePath}" FontSize="12" TextWrapping="Wrap" />
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Expander>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!-- Middle Panel -->
        <Grid Grid.Column="1" Grid.Row="0" BorderBrush="{ThemeResource SystemControlForegroundBaseLowBrush}" BorderThickness="0,0,1,0" Padding="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <TextBox Grid.Row="0" PlaceholderText="Dosya adı ile filtrele..." Text="{x:Bind ViewModel.SearchQuery, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10" />
            
            <Grid Grid.Row="1" Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0" PlaceholderText="İçerikte ara..." Text="{x:Bind ViewModel.ContentSearchQuery, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,5,0"/>
                <Button Grid.Column="1" Content="Ara" Command="{x:Bind ViewModel.ContentSearchCommand}" />
            </Grid>

            <ListView Grid.Row="2" ItemsSource="{x:Bind ViewModel.FilteredFiles, Mode=OneWay}" SelectedItem="{x:Bind ViewModel.SelectedFile, Mode=TwoWay}">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="models:SqlFileItem">
                        <StackPanel Margin="0,5">
                            <TextBlock Text="{x:Bind Name}" FontWeight="Bold" />
                            <TextBlock Text="{x:Bind LastModified, Converter={StaticResource DateTimeToStringConverter}}" FontSize="10" Foreground="Gray" />
                        </StackPanel>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Grid>

        <!-- Right Panel (Editor) -->
        <Grid Grid.Column="2" Grid.Row="0" Padding="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            
            <Grid Grid.Row="0" Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{x:Bind ViewModel.SelectedFile.Name, Mode=OneWay, FallbackValue='Dosya Seçilmedi'}" FontWeight="Bold" FontSize="18" VerticalAlignment="Center" />
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="5">
                    <Button Content="Kategori Ata">
                        <Button.Flyout>
                            <Flyout>
                                <StackPanel Spacing="10" Width="200">
                                    <TextBlock Text="Kategori Adı:" />
                                    <TextBox x:Name="CategoryInputContainer" Text="{x:Bind ViewModel.NewCategoryName, Mode=TwoWay}" />
                                    <Button Content="Kaydet" Command="{x:Bind ViewModel.AddCategoryCommand}" HorizontalAlignment="Stretch" />
                                </StackPanel>
                            </Flyout>
                        </Button.Flyout>
                    </Button>
                    <Button Content="Kopyala" Click="CopyToClipboard_Click" />
                    <Button Content="TXT Kaydet" Click="ExportToTxt_Click" />
                    <Button Content="⭐" Command="{x:Bind ViewModel.ToggleFavoriteCommand}" IsEnabled="{x:Bind ViewModel.HasSelectedFile, Mode=OneWay}" ToolTipService.ToolTip="Favorilere Ekle/Kaldır" />
                </StackPanel>
            </Grid>
            
            <controls:WebView2 x:Name="EditorWebView" Grid.Row="1" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" />
        </Grid>
        
        <!-- Loading Overlay -->
        <ProgressRing IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}" 
                      HorizontalAlignment="Center" VerticalAlignment="Center" 
                      Grid.ColumnSpan="3" Grid.RowSpan="2" Width="50" Height="50" IsEnabled="True" />
                      
        <!-- Status Bar -->
        <Border Grid.Row="1" Grid.ColumnSpan="3" Background="{ThemeResource SystemControlBackgroundChromeMediumLowBrush}" BorderBrush="{ThemeResource SystemControlForegroundBaseLowBrush}" BorderThickness="0,1,0,0" Padding="10,5">
            <StackPanel Orientation="Horizontal" Spacing="5">
                <TextBlock Text="Seçili Klasör:" FontWeight="SemiBold" FontSize="12" Foreground="Gray" />
                <TextBlock Text="{x:Bind ViewModel.RootFolderPath, Mode=OneWay, FallbackValue='Yok'}" FontSize="12" Foreground="Gray" TextTrimming="CharacterEllipsis" />
            </StackPanel>
        </Border>
    </Grid>
</Page>
